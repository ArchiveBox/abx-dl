{
  "properties": {
    "CURL_BINARY": {
      "default": "curl"
    },
    "DOCKER_BINARY": {
      "default": "docker"
    },
    "GH_BINARY": {
      "default": "gh"
    },
    "GIT_BINARY": {
      "default": "git"
    },
    "JQ_BINARY": {
      "default": "jq"
    },
    "NODE_BINARY": {
      "default": "node"
    },
    "SCRIPT_BINARY": {
      "default": "script"
    },
    "TEE_BINARY": {
      "default": "tee"
    },
    "UV_BINARY": {
      "default": "uv"
    }
  },
  "orchestration_binaries": [
    {
      "name": "{UV_BINARY}",
      "binproviders": "env,pip",
      "min_version": "0.10.6",
      "overrides": {
        "pip": {
          "install_args": [
            "uv==0.10.6"
          ]
        }
      }
    },
    {
      "name": "{CURL_BINARY}",
      "binproviders": "env,apt,brew"
    },
    {
      "name": "{GH_BINARY}",
      "binproviders": "env,apt,brew"
    },
    {
      "name": "{GIT_BINARY}",
      "binproviders": "env,apt,brew"
    },
    {
      "name": "{JQ_BINARY}",
      "binproviders": "env,apt,brew"
    }
  ],
  "docker_binaries": [
    {
      "name": "{DOCKER_BINARY}",
      "binproviders": "env"
    },
    {
      "name": "{SCRIPT_BINARY}",
      "binproviders": "env,apt",
      "overrides": {
        "env": {
          "version": [
            "script",
            "--version"
          ]
        },
        "apt": {
          "install_args": [
            "util-linux"
          ],
          "version": [
            "script",
            "--version"
          ]
        }
      }
    },
    {
      "name": "{TEE_BINARY}",
      "binproviders": "env,apt",
      "overrides": {
        "apt": {
          "install_args": [
            "coreutils"
          ]
        }
      }
    }
  ],
  "node_binaries": [
    {
      "name": "{NODE_BINARY}",
      "binproviders": "env,npm",
      "min_version": "22.23.1",
      "overrides": {
        "npm": {
          "install_args": [
            "node@22.23.1"
          ],
          "postinstall_scripts": true
        }
      }
    }
  ],
  "crawl_validation": {
    "required_plugin_outputs": {
      "dom": [
        "dom/output.html"
      ],
      "hashes": [
        "hashes/hashes.json"
      ],
      "parse_html_urls": [
        "parse_html_urls/urls.jsonl"
      ],
      "pdf": [
        "pdf/output.pdf"
      ],
      "readability": [
        "readability/content.html",
        "readability/content.txt",
        "readability/article.json"
      ],
      "screenshot": [
        "screenshot/screenshot.png"
      ],
      "singlefile": [
        "singlefile/singlefile.html"
      ],
      "title": [
        "title/title.txt"
      ],
      "wget": [
        "wget/example.com/index.html"
      ]
    }
  }
}
